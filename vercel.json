{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/proxy.js",
      "use": "@vercel/node"
    },
    {
      "src": "ui/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/proxy",
      "dest": "/api/proxy.js"
    },
    {
      "src": "/",
      "dest": "/ui/index.html"
    },
    {
      "src": "/(app.js|styles.css|ui.config.json)",
      "dest": "/ui/$1"
    },
    {
      "src": "/ui/(.*)",
      "dest": "/ui/$1"
    }
  ]
}
